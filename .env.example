# Copy to `.env` to override defaults. All values are optional.

# Which persistence backend to use: "memory" (default, no Docker) or "mongo".
REPO_BACKEND=memory

# How many times to call the LLM before giving up on bad/timed-out output.
LLM_MAX_ATTEMPTS=3

# Per-call timeout passed to the LLM client, in seconds.
LLM_TIMEOUT_SECONDS=5.0

# MongoDB connection — only used when REPO_BACKEND=mongo.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=travelio
MONGO_COLLECTION=classifications
